# ─────────────────────────────────────────
# DrivioGo Backend — Environment Variables
# ─────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# PostgreSQL — replace with your connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/driviogo?schema=public"

# JWT
JWT_SECRET="change-me-to-a-strong-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3001"
