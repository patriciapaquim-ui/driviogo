# ─────────────────────────────────────────────────────────────────
# DrivioGo — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo com suas credenciais do Supabase
# 3. NUNCA faça commit do arquivo .env (já está no .gitignore)
# ─────────────────────────────────────────────────────────────────

# URL do projeto Supabase
# Encontre em: supabase.com → seu projeto → Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública (anon/public) do Supabase — segura para expor no frontend
# Encontre em: supabase.com → seu projeto → Settings → API → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
